# Copiá este archivo a server/.env y completá los valores.
# Ver PLATFORM-SETUP.md para la guía completa.

# Conexión WhatsApp con 1 click (Embedded Signup de Meta)
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=

# Verify token del webhook de tu app de Meta
WEBHOOK_VERIFY_TOKEN=elegi_un_token_secreto

# Secreto para firmar las sesiones (cambialo por algo largo y aleatorio)
JWT_SECRET=cambiar_en_produccion

# Base de datos.
# - Dejá DATABASE_URL vacío en desarrollo: usa SQLite local en server/data/turnobot.db
# - En producción, pegá la connection string de Postgres (Neon, Supabase, Railway…):
#   DATABASE_URL=postgresql://usuario:password@host:5432/basededatos?sslmode=require
# DATABASE_URL=

# Carpeta de datos para SQLite (opcional; en hosts con volumen apuntalo ahí)
# DATA_DIR=/data

# Zona horaria del negocio (afecta "hoy" y los horarios). Recomendado en producción:
# TZ=America/Argentina/Buenos_Aires

# Puerto del server (opcional)
# PORT=4000
